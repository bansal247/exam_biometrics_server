# ── Database ──
DB_USER=exam_admin
DB_PASSWORD=
DB_NAME=exam_biometrics
DB_HOST=db
DB_PORT=5432

# ── Encryption (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
DB_ENCRYPTION_KEY=

# ── JWT ──
JWT_SECRET=change_me_jwt_secret_key_256bit
JWT_ALGORITHM=HS256

# ── Admin ──
ADMIN_ID=
ADMIN_PASSWORD=

# ── AWS Rekognition ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# ── SourceAFIS (internal network) ──
SOURCEAFIS_URL=http://sourceafis:8080
IRIS_ENDPOINT=http://192.168.1.6:8080

# ── Ports ──
API_PORT=8000
ADMIN_PORT=3000
SUPERVISOR_PORT=3001

# ── CORS (admin panel + supervisor panel origins) ──
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

LOAD_TOKEN=some-secret