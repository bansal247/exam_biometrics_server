# AWS environment — copy to .env.aws and fill in all blank values.
# DO NOT commit .env.aws to version control.

# ── RDS (PostgreSQL endpoint — NOT localhost) ────────────────────────────
# Find this in AWS Console → RDS → your instance → Endpoint
RDS_ENDPOINT=exam-biometrics-db.xxxxxxxxxxxxxxxxxx.ap-south-1.rds.amazonaws.com
DB_USER=exam_admin
DB_PASSWORD=
DB_NAME=exam_biometrics
# DB_HOST is intentionally absent here — docker-compose.aws.yml sets it
# to 'pgbouncer' for server/scheduler so they route through the pooler.

# ── Encryption ───────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DB_ENCRYPTION_KEY=

# ── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_ALGORITHM=HS256

# ── Admin credentials ────────────────────────────────────────────────────
ADMIN_ID=
ADMIN_PASSWORD=

# ── AWS Rekognition ──────────────────────────────────────────────────────
# Leave blank if the EC2 instance has an IAM role with Rekognition permissions
# (recommended — avoids storing long-term credentials on the server).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# ── Internal service URLs ─────────────────────────────────────────────────
# sourceafis runs inside Docker on the internal network.
SOURCEAFIS_URL=http://sourceafis:8080
# iris server runs on the EC2 host via systemd; containers reach it through
# the Docker host-gateway alias set in docker-compose.aws.yml.
IRIS_ENDPOINT=http://host.docker.internal:8080

# ── CORS ─────────────────────────────────────────────────────────────────
# Add your EC2 Elastic IP (and domain if you have one).
# Example: http://13.233.xx.xx,https://exam.yourorg.com
ALLOWED_ORIGINS=http://YOUR_EC2_ELASTIC_IP

# ── Load testing (leave blank in production) ─────────────────────────────
LOAD_TOKEN=
